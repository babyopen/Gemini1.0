#### 3. **智能数据同步策略**

```javascript
// 同步管理器
class SyncManager {
  constructor() {
    this.isOnline = navigator.onLine;
    this.syncInProgress = false;
    
    // 监听网络状态
    window.addEventListener('online', () => this.handleOnline());
    window.addEventListener('offline', () => this.handleOffline());
  }

  async handleOnline() {
    console.log('[Sync] 🌐 网络已恢复，开始同步离线数据...');
    this.isOnline = true;
    await this.syncPendingOperations();
  }

  handleOffline() {
    console.log('[Sync] 📴 网络已断开，进入离线模式');
    this.isOnline = false;
  }

  async syncPendingOperations() {
    if (this.syncInProgress) return;
    this.syncInProgress = true;
    
    try {
      const pendingOps = await offlineDB.getPendingOperations();
      
      if (pendingOps.length === 0) {
        console.log('[Sync] ✅ 没有待同步的操作');
        return;
      }
      
      console.log(`[Sync] 📤 开始同步 ${pendingOps.length} 个操作...`);
      
      for (const op of pendingOps) {
        try {
          await this.syncOperation(op);
          await offlineDB.clearSyncedOperation(op.id);
          console.log(`[Sync] ✅ 已同步操作 #${op.id}`);
        } catch (error) {
          if (error.status === 409) {
            // 冲突处理
            await this.handleConflict(op, error.serverData);
          } else {
            console.error(`[Sync] ❌ 同步失败:`, error);
          }
        }
      }
      
      Toast.show(`已同步 ${pendingOps.length} 条离线数据`);
    } catch (error) {
      console.error('[Sync] ❌ 同步过程出错:', error);
    } finally {
      this.syncInProgress = false;
    }
  }

  async syncOperation(operation) {
    const endpoints = {
      saveRecord: '/api/records',
      checkRecord: '/api/records/check',
      deleteRecord: '/api/records/delete'
    };
    
    const response = await fetch(endpoints[operation.type], {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(operation.data)
    });
    
    if (!response.ok) {
      throw { status: response.status, serverData: await response.json() };
    }
    
    return response.json();
  }

  async handleConflict(localOp, serverData) {
    // 冲突解决策略：本地优先或服务器优先
    const strategy = await this.chooseConflictStrategy(localOp, serverData);
    
    if (strategy === 'local') {
      // 强制使用本地数据
      await this.forceSync(localOp);
      Toast.show('使用本地数据，已覆盖服务器记录');
    } else {
      // 使用服务器数据
      await offlineDB.saveRecord(serverData, true);
      Toast.show('已更新为最新服务器数据');
    }
  }

  async chooseConflictStrategy(localOp, serverData) {
    // 可以让用户选择，或根据时间戳自动判断
    const localTime = localOp.timestamp;
    const serverTime = serverData.updatedAt || serverData.timestamp;
    
    // 最近的更新优先
    return localTime > serverTime ? 'local' : 'server';
  }
}

const syncManager = new SyncManager();
```

#### 4. **数据压缩优化**

```javascript
// 使用 LZ-string 压缩大数据
import LZString from 'lz-string';

const StorageWithCompression = {
  set: (key, value) => {
    const serialized = JSON.stringify(value);
    
    // 小数据不压缩
    if (serialized.length < 1000) {
      return localStorage.setItem(key, serialized);
    }
    
    // 大数据压缩
    const compressed = LZString.compressToUTF16(serialized);
    localStorage.setItem(key, compressed);
    localStorage.setItem(`${key}_compressed`, 'true');
  },

  get: (key, defaultValue = null) => {
    const value = localStorage.getItem(key);
    if (!value) return defaultValue;
    
    const isCompressed = localStorage.getItem(`${key}_compressed`) === 'true';
    
    if (isCompressed) {
      return JSON.parse(LZString.decompressFromUTF16(value));
    }
    
    return JSON.parse(value);
  }
};
```

